{
  "name": "nofile",
  "version": "1.0.0",
  "description": "NoFile - 文件暂存站，自动捕获截图和下载文件的桌面工具",
  "main": "dist/main/index.js",
  "homepage": "https://github.com/HXZ09845/nofile#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HXZ09845/nofile.git"
  },
  "bugs": {
    "url": "https://github.com/HXZ09845/nofile/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "macos",
    "desktop-app",
    "file-management",
    "screenshot",
    "clipboard",
    "productivity"
  ],
  "author": "Jerry",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "electron-store": "^8.1.0",
    "uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.nofile.app",
    "productName": "NoFile",
    "copyright": "Copyright © 2024 Jerry",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "artifactName": "${productName}-${version}-mac-arm64.${ext}"
    },
    "dmg": {
      "title": "NoFile 安装程序",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ]
  }
}
